FROM alpine:latest

# Install required tools for API-based approach
RUN apk add --no-cache \
    curl \
    ca-certificates \
    jq \
    uuidgen \
    bash \
    && echo "Tools installed successfully"

# Copy the API-based entrypoint script
COPY entrypoint-api.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Verify tools are working
RUN curl --version && jq --version && bash --version

ENTRYPOINT ["/entrypoint.sh"]