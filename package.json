{
  "name": "action-tower-launch",
  "version": "3.0.0",
  "description": "Launch Nextflow workflows on Seqera Platform via JavaScript action",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "lint": "eslint src/**/*.js",
    "package": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seqeralabs/action-tower-launch.git"
  },
  "keywords": [
    "github-action",
    "nextflow",
    "seqera",
    "tower",
    "workflow",
    "bioinformatics"
  ],
  "author": "Phil Ewels",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/http-client": "^2.2.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20"
  }
}